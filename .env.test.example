# Automated test profile. Copy to .env only for local test runs that need explicit overrides.
# HYDRA_ENVIRONMENT should resolve to test for automation.
HYDRA_APP_NAME=<app_name>
HYDRA_APP_VERSION=<app_version>
HYDRA_ENVIRONMENT=<environment_must_be_test>
HYDRA_API_PREFIX=<api_prefix_default_/api/v1>
HYDRA_DATABASE_URL=postgresql+psycopg://<test_db_user>:<test_db_password>@<test_db_host>:<test_db_port>/<test_db_name>
HYDRA_REDIS_URL=redis://<test_redis_host>:<test_redis_port>/<test_redis_db>
HYDRA_LOG_LEVEL=<log_level_default_WARNING>
