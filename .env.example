# Generic HYDRA configuration template. Copy to .env and replace every placeholder.
HYDRA_APP_NAME=<app_name>
HYDRA_APP_VERSION=<app_version>
HYDRA_ENVIRONMENT=<environment: local|test|dev|staging|production-like>
HYDRA_API_PREFIX=<api_prefix: /api/v1>
HYDRA_DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>
HYDRA_REDIS_URL=redis://<redis_host>:<redis_port>/<redis_db>
HYDRA_LOG_LEVEL=<log_level: DEBUG|INFO|WARNING|ERROR|CRITICAL>
