# Local developer machine profile. Copy to .env and replace every placeholder.
# HYDRA_ENVIRONMENT should resolve to local for workstation use.
HYDRA_APP_NAME=<app_name>
HYDRA_APP_VERSION=<app_version>
HYDRA_ENVIRONMENT=<environment_must_be_local>
HYDRA_API_PREFIX=<api_prefix_default_/api/v1>
HYDRA_DATABASE_URL=postgresql+psycopg://<local_db_user>:<local_db_password>@<local_db_host>:<local_db_port>/<local_db_name>
HYDRA_REDIS_URL=redis://<local_redis_host>:<local_redis_port>/<local_redis_db>
HYDRA_LOG_LEVEL=<log_level_default_DEBUG>
